# Supabase — copy this file to `.env` and fill in your project's values.
# Find these in the Supabase dashboard: Project Settings → API.
#
# Until these are set, the quote form will ask visitors to call/text instead
# of saving the lead. Once set, submissions are stored in the quote_requests
# table automatically.

PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# --- Optional: Search Console + analytics (leave blank to disable) ----------
# Google Search Console: paste ONLY the content value from the
# "HTML tag" verification method (the google-site-verification token).
PUBLIC_GSC_VERIFICATION=

# Plausible Analytics (privacy-friendly, no cookie banner needed). Set this to
# your site's domain, e.g. koldarc.com, after creating the site in Plausible.
PUBLIC_PLAUSIBLE_DOMAIN=

# --- Pre-launch takedown ----------------------------------------------------
# Set to "true" to replace the ENTIRE public site with a noindex
# "Launching soon" holding page. Set to "false" (or remove) to go live.
# On Vercel this is an Environment Variable; changing it requires a redeploy.
PUBLIC_MAINTENANCE=false
