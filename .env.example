# Supabase — copy this file to `.env` and fill in your project's values.
# Find these in the Supabase dashboard: Project Settings → API.
#
# Until these are set, the quote form will ask visitors to call/text instead
# of saving the lead. Once set, submissions are stored in the quote_requests
# table automatically.

PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
